# Active example below is for IP deployment behind Nginx.
# For local testing, copy this file to .env and switch to the commented local values.

# Deploy: production. Local: development.
# APP_ENV=development
APP_ENV=production

# Deploy behind Nginx: keep backend private on localhost.
# Local direct testing from another device can use HOST=0.0.0.0.
# HOST=0.0.0.0
HOST=127.0.0.1
PORT=5000

# Deploy: false. Local debugging: true.
# DEBUG=true
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-secret

# Deploy by IP through Nginx.
# Local Vite dev server:
# FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
FRONTEND_ORIGIN=http://89.207.254.30

# Deploy: PostgreSQL. Local quick testing can use SQLite.
# DATABASE_URL=sqlite:///backend/data/alignd.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alignd
APIFY_TOKEN=your_apify_token
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-scraper
APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-profile-scraper
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TREND_MODEL=gemini-2.5-flash

# Fallback models are tried automatically when Gemini returns 429/5xx.
# Trend fallbacks should be Gemini models that support Google Search grounding.
# Analysis fallback can use Gemma through the same Gemini API.
GEMINI_FALLBACK_MODELS=gemma-4-31b-it
GEMINI_TREND_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
ENABLE_SEARCH_GROUNDING=true
SESSION_COOKIE_NAME=alignd_session

# HTTP by IP or local: false. HTTPS with domain: true.
# SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_HOURS=24
ANALYSIS_CACHE_TTL_MINUTES=60
ANALYSIS_LIMIT_PER_HOUR=25
AUTH_LIMIT_PER_15_MINUTES=10
